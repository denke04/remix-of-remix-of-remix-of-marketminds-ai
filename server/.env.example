# Supabase Configuration
# Get these values from your Supabase project settings: https://app.supabase.com
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key_or_service_role_key

# Note: For server-side operations, you can use either:
# - anon key (with RLS disabled or proper policies)
# - service_role key (bypasses RLS, recommended for trusted server operations)
